<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Plain console output keeps container log levels machine-detectable. -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg %kvp%n</pattern>
        </encoder>
    </appender>

    <!-- File appender for pipeline logs -->
    <appender name="PIPELINE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/pipeline.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/pipeline-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{ISO8601} [%thread] %-5level %logger - %msg %kvp%n</pattern>
        </encoder>
    </appender>

    <!-- Pipeline logger configuration (no async to avoid shutdown races) -->
    <logger name="PIPELINE" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="PIPELINE_FILE"/>
    </logger>

    <!-- Application loggers -->
    <logger name="com.williamcallahan.javachat" level="INFO"/>
    
    <!-- Spring framework loggers -->
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.ai" level="INFO"/>
    
    <!-- Qdrant client logger -->
    <logger name="io.qdrant" level="ERROR"/>
    
    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
